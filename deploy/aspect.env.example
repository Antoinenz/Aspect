# Aspect server configuration.
# Copy to /etc/aspect/aspect.env and `chmod 600`. Owner should be the service
# user (e.g. `chown aspect:aspect`). This file holds the HA token — treat as
# a secret.

# --- Home Assistant ---
HA_URL=http://homeassistant.local:8123
HA_TOKEN=replace-with-your-long-lived-access-token

# --- Web ---
# Path to the built web assets, relative to WorkingDirectory (or absolute).
ASPECT_WEB_DIR=apps/web/dist

# --- Server ---
PORT=8099
HOST=0.0.0.0

# --- Storage ---
# Favourites & settings DB. Must be writable by the service user and listed
# in ReadWritePaths= in aspect.service.
ASPECT_DB=/opt/aspect/data/aspect.db
