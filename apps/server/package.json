    "fastify": "5.1.0"
  },
  "devDependencies": {
    "@types/node": "22.10.1",
    "@types/ws": "8.5.13",
    "tsup": "8.3.5",
    "tsx": "4.19.2",
    "typescript": "5.7.2",
    "vitest": "3.0.5",
    "ws": "8.18.0"
  }
}
